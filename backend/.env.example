# Ihy backend configuration — copy to .env and adjust.
# All variables use the IHY_ prefix.

# JWT signing key: set a strong random value of at least 32 bytes
# (e.g. `openssl rand -hex 32`)
IHY_SECRET_KEY=insecure-dev-only-secret-key-change-me-in-production

# Directory for database, cover cache and app state
IHY_DATA_DIR=./data

# Leave empty to use SQLite inside IHY_DATA_DIR
IHY_DATABASE_URL=

IHY_DEBUG=false
